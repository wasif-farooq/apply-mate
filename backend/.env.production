# Production Environment Variables for Backend
# Copy this to .env before deployment and update values

# Database
DB_USER=applymate
DB_PASSWORD=generate_strong_password_here
DB_NAME=applymate
DATABASE_URL=postgresql://applymate:generate_strong_password_here@localhost:5432/applymate

# Security - GENERATE NEW SECURE KEY
JWT_SECRET=generate_a_long_random_string_here_min_32_chars

# Frontend URL (update to your production domain)
FRONTEND_URL=https://yourdomain.com

# AI Provider: openai, anthropic, google, ollama
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Anthropic Configuration (if using)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini Configuration (if using)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-1.5-pro

# Ollama Configuration (if using local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# Gmail Configuration
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password
GMAIL_SENDER_NAME=Your Name

# Google OAuth (create new credentials for production)
GOOGLE_CLIENT_ID=your-production-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-production-client-secret

# Extension Google OAuth (separate client)
EXTENSION_GOOGLE_CLIENT_ID=your-extension-client-id.apps.googleusercontent.com
EXTENSION_GOOGLE_CLIENT_SECRET=your-extension-client-secret

# CORS - Update to production domain
CORS_ORIGINS=https://yourdomain.com